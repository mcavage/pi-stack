# pi-stack local config. `make install` copies this to config/local.mk (which is
# gitignored). This is the SINGLE place to configure the stack — make serve / run
# / mcp-register / doctor / pull-models all read from here, so you never pass
# flags by hand.

# Host services `make serve` runs. Valid: memory, gws. Trim to what you use.
SERVICES = memory gws

# MCP servers `make run` auto-attaches and `make mcp-register` registers.
# IMPORTANT: local stdio servers (e.g. slack) MUST be listed here to be usable —
# dynamic discovery does NOT surface them, and this sbx can't attach to a running
# sandbox. Leave empty for pure dynamic mode (remote catalog only).
MCP = slack

# Local Ollama models for the self-learning memory (`make pull-models` fetches
# them). watcher = fact capture, embed = semantic recall.
MEMORY_WATCHER_MODEL = gemma4
MEMORY_EMBED_MODEL   = nomic-embed-text

# Private, company-specific integrations (a Snowflake proxy, a BambooHR directory,
# etc.) live in config/overlay.mk + gitignored services/host/*.go — not in this
# public config.
