# Template. Copy to config/op-refs.env (gitignored) and fill in your 1Password
# refs:  cp config/op-refs.env.example config/op-refs.env
#
# These are resolved by `op run --env-file` when the sbx gateway spawns each host
# MCP server (see `make mcp-register`). Credentials live ONLY in 1Password — never
# in the sbx registration, on disk, or in the sandbox. One file, one mechanism.
#
# Format:  ENV_VAR=op://<vault>/<item>/<field>     (plain literals are allowed too)
# Verify:  op read "op://Vault/Item/field" >/dev/null && echo OK
# Tip:     1Password app -> right-click a field -> "Copy Secret Reference" gives the
#          exact ref (and disambiguates duplicate item names by ID).

SLACK_TOKEN=op://<vault>/<slack-item>/credential

# Private overlay servers add their own refs here (kept out of the public repo).
