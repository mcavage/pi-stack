# Build context for the PUBLIC image. Keep it tight, and — critically — keep the
# company/overlay content OUT of the published image.

.git
.gitignore
README.md
Makefile
pi-kit/
docs/
config/
out/
*.zip
*.tar
node_modules/
.DS_Store
**/*.db
**/*.db-*
services/host/pi-stack-host

# --- Open-core boundary: skills -------------------------------------------------
# DEFAULT-DENY. The Dockerfile COPYs skills/ wholesale, so we exclude every skill
# here and re-include ONLY the generic, open-source-safe ones below. Company /
# sales / HR / finance / Docker-internal-data / connector-specific skills
# (account-*, deal-review, financial-model, cso, snowflake, google-workspace,
# find-internal, plan-gm-review, …) are intentionally NOT baked into the public
# image — they live in the working tree / a private overlay kit only.
# Review this allowlist before every public build. To publish a skill, add a
# "!skills/<name>" line. Anything not listed is excluded by default (safe).
skills/*
!skills/anti-slop
!skills/api-conventions
!skills/autoplan
!skills/brainstorm
!skills/capability-routing
!skills/challenge
!skills/code-review
!skills/competitive-analysis
!skills/conventions
!skills/delegation-guide
!skills/design-review
!skills/design-system
!skills/docs-standards
!skills/document-release
!skills/git-conventions
!skills/guard
!skills/health
!skills/ingest
!skills/investigate
!skills/microcopy-patterns
!skills/promote-learnings
!skills/prototype-webapp
!skills/qa
!skills/review-gate
!skills/self-audit
!skills/setup-user
!skills/ship
!skills/spec
!skills/tdd
!skills/verify
!skills/wf-engineering
!skills/wf-product
!skills/wf-prototype
!skills/write-like-mark
!skills/write-one-pager

# --- Open-core boundary: agents (personas) -------------------------------------
# DEFAULT-DENY, same as skills. The Dockerfile COPYs agents/ wholesale; exclude
# every persona and re-include only the generic ones. A future company-specific
# persona then can't auto-bake into the public image — it must be added here.
agents/*
!agents/architect.md
!agents/deep.md
!agents/designer.md
!agents/devrel.md
!agents/dx-consultant.md
!agents/engineer.md
!agents/enterprise-admin.md
!agents/fanout.md
!agents/finance-analyst.md
!agents/growth-marketing.md
!agents/legal.md
!agents/product-manager.md
!agents/qa-lead.md
!agents/review.md
!agents/security-lead.md
!agents/sre-lead.md
!agents/ux-copywriter.md
