#!/bin/bash
# pi-stack wrapper for Google Workspace CLI.
#
# The real binary is /usr/local/bin/_gws. This wrapper asks a host-side token
# service for a fresh short-lived bearer and passes it to gws. Long-lived Google
# OAuth refresh credentials stay on the host.

set -euo pipefail

REAL_GWS=/usr/local/bin/_gws
TOKEN_URL=${GWS_TOKEN_URL:-http://host.docker.internal:11441/token}

if [ ! -x "$REAL_GWS" ]; then
	echo "gws wrapper: $REAL_GWS is missing" >&2
	exit 127
fi

headers=(-H "accept: application/json")
if [ -n "${GWS_TOKEN_AUTH:-}" ]; then
	headers+=(-H "authorization: Bearer ${GWS_TOKEN_AUTH}")
fi

token_json=$(curl -fsS --max-time 5 "${headers[@]}" "$TOKEN_URL" 2>/dev/null || true)
token=""
if [ -n "$token_json" ]; then
	token=$(printf '%s' "$token_json" | python3 -c 'import json, sys; print(json.load(sys.stdin).get("access_token", ""))' 2>/dev/null || true)
fi

if [ -n "$token" ]; then
	exec env GOOGLE_WORKSPACE_CLI_TOKEN="$token" "$REAL_GWS" "$@"
fi

echo "gws wrapper: no host token from $TOKEN_URL; running _gws unauthenticated" >&2
exec "$REAL_GWS" "$@"
