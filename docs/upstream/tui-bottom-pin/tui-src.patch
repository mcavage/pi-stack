--- a/packages/tui/src/tui.ts
+++ b/packages/tui/src/tui.ts
@@ -1458,6 +1458,72 @@ export class TUI extends Container {
 			return;
 		}
 
+		// Bottom-block pin: a bottom-anchored buffer SHRINK that reaches this point
+		// (the changed region is within the visible window, so neither the
+		// deleted-tail branch nor the `firstChanged < prevViewportTop` guard above
+		// fired) would otherwise have the differential loop below re-emit the
+		// unchanged bottom block (editor / widgets / footer) one or more rows higher,
+		// because that loop renders relative to the un-re-anchored viewportTop. The
+		// input box + any belowEditor widgets then visibly jump up while streaming
+		// (markdown re-wrap, the hidden "Thinking..." spacer toggling, tool rows
+		// collapsing). Re-anchor to the new bottom and repaint the whole visible
+		// window in place: lines that scrolled just out of view above are pulled back
+		// down to fill the freed rows, so the bottom block keeps its exact screen
+		// rows — no jump, no full-screen clear.
+		//
+		// Scoped to the genuine jitter case only: bottom-anchored before AND after
+		// the shrink, no overlays, and no kitty images in the visible window (those
+		// need the reservation path in the differential loop). The deliberate
+		// full-redraw-on-shrink behaviours (deleted-tail moving the viewport up;
+		// stale content from an inflated maxLinesRendered) return via the guards
+		// ABOVE this point and are unaffected.
+		if (
+			this.overlayStack.length === 0 &&
+			prevViewportTop > 0 &&
+			prevViewportTop === this.previousLines.length - height &&
+			newLines.length < this.previousLines.length &&
+			newLines.length >= height &&
+			this.previousKittyImageIds.size === 0
+		) {
+			const newViewportTop = newLines.length - height;
+			let visibleImage = false;
+			for (let r = 0; r < height; r++) {
+				if (isImageLine(newLines[newViewportTop + r] ?? "")) {
+					visibleImage = true;
+					break;
+				}
+			}
+			if (!visibleImage) {
+				logRedraw(`bottom-anchored shrink pin (viewportTop ${prevViewportTop} -> ${newViewportTop})`);
+				let pinBuffer = "\x1b[?2026h"; // Begin synchronized output
+				// Move the hardware cursor to the top row of the visible screen.
+				const screenCursorRow = Math.max(0, Math.min(height - 1, hardwareCursorRow - prevViewportTop));
+				if (screenCursorRow > 0) {
+					pinBuffer += `\x1b[${screenCursorRow}A`;
+				}
+				pinBuffer += "\r";
+				// Repaint every visible row with bottom-anchored content.
+				for (let r = 0; r < height; r++) {
+					if (r > 0) pinBuffer += "\r\n";
+					pinBuffer += "\x1b[2K";
+					pinBuffer += newLines[newViewportTop + r] ?? "";
+				}
+				pinBuffer += "\x1b[?2026l"; // End synchronized output
+				this.terminal.write(pinBuffer);
+				// Cursor now sits on the last visible row = end of content.
+				this.cursorRow = newLines.length - 1;
+				this.hardwareCursorRow = newLines.length - 1;
+				this.maxLinesRendered = Math.max(this.maxLinesRendered, newLines.length);
+				this.previousViewportTop = newViewportTop;
+				this.positionHardwareCursor(cursorPos, newLines.length);
+				this.previousLines = newLines;
+				this.previousKittyImageIds = this.collectKittyImageIds(newLines);
+				this.previousWidth = width;
+				this.previousHeight = height;
+				return;
+			}
+		}
+
 		// Render from first changed line to end
 		// Build buffer with all updates wrapped in synchronized output
 		let buffer = "\x1b[?2026h"; // Begin synchronized output
