@@ -764,4 +766,55 @@ describe("TUI differential rendering", () => {
 
 		tui.stop();
 	});
+
+	it("pins the bottom block in place on a small bottom-anchored shrink (no jump, no full redraw)", async () => {
+		// Regression for the streaming jitter: when chat content above the editor
+		// shrinks by a line (markdown re-wrap, "Thinking..." spacer, tool-row
+		// collapse), the editor / footer below it must keep their exact screen rows
+		// instead of drifting up, and it must do so smoothly (no full screen clear).
+		const terminal = new VirtualTerminal(40, 10);
+		const tui = new TUI(terminal);
+		const chat = new TestComponent();
+		const editor = new TestComponent();
+		tui.addChild(chat);
+		tui.addChild(editor);
+
+		chat.lines = Array.from({ length: 12 }, (_, i) => `Chat ${i}`);
+		editor.lines = ["Editor 0", "Editor 1"];
+		tui.start();
+		await terminal.waitForRender();
+
+		const before = terminal.getViewport();
+		const editorRowBefore = before.indexOf("Editor 0");
+		assert.strictEqual(before[9], "Editor 1", "editor pinned to bottom row initially");
+		const redrawsBefore = tui.fullRedraws;
+
+		// Chat shrinks by one line; the bottom block is unchanged.
+		chat.lines = Array.from({ length: 11 }, (_, i) => `Chat ${i}`);
+		tui.requestRender();
+		await terminal.waitForRender();
+
+		const after = terminal.getViewport();
+		assert.strictEqual(
+			after.indexOf("Editor 0"),
+			editorRowBefore,
+			"editor stayed on the same screen row across the shrink",
+		);
+		assert.strictEqual(after[9], "Editor 1", "editor still pinned to the bottom row");
+		assert.strictEqual(tui.fullRedraws, redrawsBefore, "pin is smooth (no full redraw)");
+		assert.deepStrictEqual(after, [
+			"Chat 3",
+			"Chat 4",
+			"Chat 5",
+			"Chat 6",
+			"Chat 7",
+			"Chat 8",
+			"Chat 9",
+			"Chat 10",
+			"Editor 0",
+			"Editor 1",
+		]);
+
+		tui.stop();
+	});
 });
